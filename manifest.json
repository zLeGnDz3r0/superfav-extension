{
  "manifest_version": 3,
  "name": "SuperFav for Twitch",
  "version": "1.0.0",
  "description": "Marca tus streamers favoritos y míralos en directo desde un dashboard minimalista.",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "host_permissions": [
    "https://*.twitch.tv/*",
    "https://api.twitch.tv/*",
    "https://superfavtwitch.onrender.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "SuperFav for Twitch",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["src/content/injectSuperFav.ts"],
      "run_at": "document_idle"
    }
  ]
}
